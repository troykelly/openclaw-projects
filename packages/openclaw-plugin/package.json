{
  "name": "@troykelly/openclaw-projects",
  "version": "0.0.65",
  "description": "OpenClaw memory plugin with projects, todos, and contacts integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register-openclaw.d.ts",
      "import": "./dist/register-openclaw.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint . && pnpm run lint:no-manual-prefix",
    "lint:no-manual-prefix": "! grep -rn --include='*.ts' -E '\\[(openclaw-projects|plugins)\\]' src/ --exclude='logger.ts' --exclude='startup.ts' | grep -v 'biome-ignore' | grep -v '// eslint-disable' | grep -qv '^$'",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test && pnpm run typecheck && pnpm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/troykelly/openclaw-projects.git",
    "directory": "packages/openclaw-plugin"
  },
  "bugs": {
    "url": "https://github.com/troykelly/openclaw-projects/issues"
  },
  "homepage": "https://github.com/troykelly/openclaw-projects/tree/main/packages/openclaw-plugin#readme",
  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "projects",
    "todos",
    "contacts"
  ],
  "author": "Troy Kelly",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "openclaw": "2026.3.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "openclaw": {
    "extensions": [
      "dist/register-openclaw.js"
    ]
  }
}
